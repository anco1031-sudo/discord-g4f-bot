# ═══════════════════════════════════════════════════════════
# Environment Variables — Discord Bot + g4f
# ═══════════════════════════════════════════════════════════
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าของคุณ
# ═══════════════════════════════════════════════════════════

# Discord Bot Token (จำเป็น!) → https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# g4f model — ใช้ "default" เพื่อ auto-select provider
G4F_MODEL=default

# Prefix สำหรับคำสั่ง (default: !)
BOT_PREFIX=!

# ชื่อคำสั่งหลัก (default: ask) → ใช้ !ask <คำถาม>
COMMAND_NAME=ask

# Cooldown: กี่วินาทีให้ถามซ้ำได้ (default: 30)
COOLDOWN_SECONDS=30

# Timeout: กี่วินาทีให้รอ g4f ก่อนตัดว่า timeout (default: 60)
G4F_TIMEOUT=60

# ถ้าอยากจำกัดให้แค่ user ID เดียวใช้ได้ (ไม่ใส่ = ใครก็ใช้ได้)
# OWNER_ID=123456789012345678
